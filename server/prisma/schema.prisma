generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VIEWER
  UPLOADER
  ADMIN
}

enum VideoStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  DELETED
}

enum UploadSessionStatus {
  INITIATED
  UPLOADING
  COMPLETED
  CANCELED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                Role                 @default(VIEWER)
  uploadQuotaBytes    BigInt               @default(10737418240)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  videos              Video[]
  uploadSessions      UploadSession[]
  passwordResetTokens PasswordResetToken[]
}

model Video {
  id          String      @id @default(cuid())
  title       String
  ossKey      String      @unique
  sizeBytes   BigInt
  status      VideoStatus @default(PENDING)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  uploaderId  String
  uploader    User        @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  userId     String
  requesterIp String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model UploadSession {
  id            String              @id @default(cuid())
  title         String
  filename      String
  mimeType      String
  fileSizeBytes BigInt
  uploadId      String              @unique
  ossKey        String?
  ossUploadId   String?
  partSizeBytes Int
  uploadedParts Json                @default("[]")
  status        UploadSessionStatus @default(INITIATED)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  uploaderId    String
  uploader      User                @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([uploaderId, createdAt])
}
